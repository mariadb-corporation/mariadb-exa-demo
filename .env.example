# Community Docker Images
IMAGE_EXASOL=exasol/docker-db:latest
IMAGE_MARIADB=mariadb:11.8
IMAGE_MAXSCALE=mariadb/maxscale-trial:25.10.3 

# Enterprise Docker Images
#IMAGE_EXASOL=exasol/docker-db:latest
#IMAGE_MARIADB=docker.mariadb.com/enterprise-server:11.8
#IMAGE_MAXSCALE=docker.mariadb.com/maxscale:25.10.3-all

# Comma separated list of databases to replicate to Exasol
CDC_DATABASES=mariadb_exa_demo

# Vue App & API Configuration
# Update to public IP or hostname if running on EC2
ENABLE_VUE_APP_AND_API=false
PUBLIC_HOST=localhost

##########################################################################
# Optional - Not required to change any of these variables below this line
##########################################################################
API_PORT=3000

# Default Mount Paths
MARIADB_DATA_MOUNT=./mounts/mariadb/mariadb-data
EXASOL_DATA_MOUNT=./mounts/exa-data

# MaxScale
MAXSCALE_MARIADB_PORT=3306
MAXSCALE_MARIADB_EXA_PORT=3310
MAXSCALE_EXASOL_ONLY_PORT=3311
MAXSCALE_GUI_PORT=8989
MAXSCALE_MONITOR_USER=maxuser
MAXSCALE_MONITOR_PASSWORD=aBcd123%

# Default Sales Simulator Configuration
SALES_PER_MINUTE=1000
BATCH_SIZE=50
WORKER_COUNT=20
LOG_ALL=true

# MariaDB Configuration
DB_HOST=mariadb
DB_PORT=3307
DB_USER=admin_user
DB_PASSWORD=aBc123%%
DB_NAME=mariadb_exa_demo

# Exasol Configuration
EXA_HOST=exasoldb
EXA_PORT=8563
EXA_FINGERPRINT=NOCERTCHECK
SERVICE_EXA_USER=sys
SERVICE_EXA_PASSWORD=exasol
CDC_EXA_USER=cdc_user
CDC_EXA_PASSWORD=aBcd123%

# Container Names
MARIADB_CONTAINER_NAME=mariadb
EXASOL_CONTAINER_NAME=exasoldb
MAXSCALE_CONTAINER_NAME=maxscale
DEBEZIUM_CONTAINER_NAME=debezium

